# ── Required ──────────────────────────────────────────────────────────────────
# Set this to the API key for whichever provider MODEL/MODEL_JUDGE point to.
# Anthropic: sk-ant-...  |  OpenAI: sk-...  |  OpenRouter: sk-or-...  |  Gemini: AI...
LLM_API_KEY=your_api_key_here

OPIK_API_KEY=your_opik_api_key_here
OPIK_PROJECT_NAME=text_to_sql_pm_demo

# ── Optional: override models via environment ──────────────────────────────────
# Defaults are set in config.py. Uncomment to override without editing code.
# MODEL=gpt-4.1
# MODEL_JUDGE=gpt-4.1-mini
